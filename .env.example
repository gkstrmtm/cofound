# do not commit your real key. copy this file to .env
OPENAI_API_KEY=
# optional
OPENAI_MODEL=gpt-4.1-mini

# optional but recommended for real auth + saved progress
SUPABASE_URL=
# use the supabase "anon public" / publishable key here, not the secret key
SUPABASE_ANON_KEY=
# accepted alias if you prefer matching supabase naming
SUPABASE_PUBLISHABLE_KEY=
# optional server-side admin key to auto-confirm signups and skip email confirmation
SUPABASE_SERVICE_ROLE_KEY=
# accepted alias if you only have the newer supabase secret key naming
SUPABASE_SECRET_KEY=
